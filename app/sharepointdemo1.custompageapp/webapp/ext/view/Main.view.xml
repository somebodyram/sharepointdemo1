<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:u="sap.ui.unified"
  controllerName="sharepointdemo1.custompageapp.ext.view.Main">

  <VBox
    id="mainVBox"
    class="sapUiSmallMargin"
    width="100%">

    <!-- Excel upload -->
    <u:FileUploader
      id="excelUploader"
      fileType="xlsx,xls"
      placeholder="Choose Excel file"
      width="50%" />

    <HBox id="buttonBox" class="sapUiSmallMargin">
      <Button id="btnRead" text="Read Excel" press="onReadExcel"/>
      <Button id="btnProcess" text="Process Excel" press="onProcessExcel"/>
      <Button id="btnDownload" text="Download Excel" press="onDownloadExcel"/>
    </HBox>

    <!-- Results Table -->
    <Table
      id="resultTable"
      class="sapUiSmallMarginTop"
      items="{excelModel>/}"
      width="100%">

      <columns>
        <Column id="colEmpId">
          <Text id="txtColEmpId" text="Employee ID"/>
        </Column>

        <Column id="colEmpName">
          <Text id="txtColEmpName" text="Employee Name"/>
        </Column>

        <Column id="colDept">
          <Text id="txtColDept" text="Department"/>
        </Column>

        <Column id="colStatus">
          <Text id="txtColStatus" text="Status"/>
        </Column>

        <Column id="colRating">
          <Text id="txtRating" text="Rating"/>
        </Column>

        <Column id="colExperience">
          <Text id="txtExperience" text="Experience"/>
        </Column>

        <Column id="colCountry">
          <Text id="txtCountry" text="Country"/>
        </Column>

      </columns>

      <items>
        <ColumnListItem id="rowItem">
          <cells>
            <Text id="cellEmpId" text="{excelModel>empId}"/>
            <Text id="cellEmpName" text="{excelModel>empName}"/>
            <Text id="cellDepartment" text="{excelModel>department}"/>  
            <ObjectStatus id="cellStatus" text="{excelModel>status}"
              state="{
                = ${excelModel>status} === 'VALID'
                  ? 'Success'
                  : 'Error'
              }"/>
            <Text id="cellRating" text="{excelModel>rating}"/>
            <Text id="cellExperience" text="{excelModel>experience}"/>
            <Text id="cellCountry" text="{excelModel>country}"/>
          </cells>
        </ColumnListItem>
      </items>

    </Table>

  </VBox>
</mvc:View>